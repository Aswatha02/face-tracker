{
  "video_source": "videos/record_20250620_183903.mp4",
  "rtsp_url": "rtsp://your_camera_ip:554/stream",
  "use_rtsp": false,

  "detection": {
    "model_path": "yolov8n-face.pt",
    "frame_skip": 4,
    "confidence_threshold": 0.5,
    "input_size": 640,
    "min_face_size": 30
  },

  "recognition": {
    "model_name": "buffalo_l",
    "similarity_threshold": 0.92,
    "embedding_size": 512
  },

  "tracking": {
    "max_age": 15,
    "min_hits": 3,
    "iou_threshold": 0.3,
    "exit_timeout_frames": 60
  },

  "logging": {
    "log_file": "logs/events.log",
    "entries_dir": "logs/entries",
    "exits_dir": "logs/exits",
    "snapshots_dir": "logs/snapshots",
    "image_format": "jpg",
    "log_level": "DEBUG"
  },

  "database": {
    "path": "face_tracker.db"
  },

  "display": {
    "show_video": true,
    "draw_boxes": true,
    "draw_labels": true,
    "window_name": "Face Tracker"
  }
}